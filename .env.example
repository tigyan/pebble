# --- Pebble configuration ---

# Absolute path to the Obsidian vault Pebble will write into.
PEBBLE_VAULT_PATH=/absolute/path/to/your/Obsidian/Vault

# SQLite DB path (defaults to <vault>/_System/pebble.sqlite if unset).
PEBBLE_DB_PATH=

# Shared secret required for inbound webhook calls (X-Pebble-Token header).
PEBBLE_INGEST_SECRET=change-me-to-a-long-random-string

# HTTP server bind.
PEBBLE_HOST=127.0.0.1
PEBBLE_PORT=8787

# --- AI / agent providers (all optional for MVP; mock classifier is used by default) ---

# anthropic | openai | claude-code | codex | mock
PEBBLE_TRIAGE_PROVIDER=mock

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: path to a Claude Code or Codex CLI binary if you want agents to drive
# the workspace through CLI tools rather than HTTP APIs.
PEBBLE_CLAUDE_CODE_BIN=
PEBBLE_CODEX_BIN=

# --- Behaviour flags ---

# Never destroy user content; this defaults to true and is here as a reminder.
PEBBLE_APPEND_ONLY=true

# Disable any kind of telemetry. Pebble itself sends no telemetry.
PEBBLE_TELEMETRY=off
