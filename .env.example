# --- Pebble configuration ---

# Absolute path to the Obsidian vault Pebble will write into.
PEBBLE_VAULT_PATH=/absolute/path/to/your/Obsidian/Vault

# SQLite DB path (defaults to <vault>/_System/pebble.sqlite if unset).
PEBBLE_DB_PATH=

# Shared secret required for inbound webhook calls (X-Pebble-Token header).
PEBBLE_INGEST_SECRET=change-me-to-a-long-random-string

# HTTP server bind.
PEBBLE_HOST=127.0.0.1
PEBBLE_PORT=8787

# --- AI / agent providers (all optional for MVP; mock classifier is used by default) ---

# anthropic | openai | claude-code | codex | mock
# Subscription mode (claude-code / codex) is the recommended primary path —
# it drives your already-logged-in CLI tools and never touches an API key.
PEBBLE_TRIAGE_PROVIDER=mock

# Subscription-mode binaries (resolved on PATH if unset).
PEBBLE_CLAUDE_CODE_BIN=
PEBBLE_CODEX_BIN=

# API-key providers (optional; used when PEBBLE_TRIAGE_PROVIDER=anthropic|openai).
# Leave blank to keep using subscription or mock mode.
PEBBLE_ANTHROPIC_API_KEY=
PEBBLE_ANTHROPIC_MODEL=claude-haiku-4-5
PEBBLE_ANTHROPIC_BASE_URL=

PEBBLE_OPENAI_API_KEY=
PEBBLE_OPENAI_MODEL=gpt-5-mini
PEBBLE_OPENAI_BASE_URL=

# Embeddings model used by `pebble embed --provider openai` and the hybrid
# search endpoint. The mock provider needs nothing extra.
PEBBLE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Behaviour flags ---

# Never destroy user content; this defaults to true and is here as a reminder.
PEBBLE_APPEND_ONLY=true

# Disable any kind of telemetry. Pebble itself sends no telemetry.
PEBBLE_TELEMETRY=off

# --- Secrets backend ---
#
# env       (default) — read secrets from this file / process.env only.
# keychain  read secrets from the OS keychain (macOS Keychain / Linux libsecret) only.
# auto      try the OS keychain first, fall back to env. Recommended once you've
#           seeded the keychain via `pebble secrets set <KEY>`.
#
# Service name in the keychain is "pebble"; account is the env-var key
# (e.g. PEBBLE_INGEST_SECRET, PEBBLE_ANTHROPIC_API_KEY, PEBBLE_OPENAI_API_KEY).
PEBBLE_SECRETS_SOURCE=env
