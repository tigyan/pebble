{
  "name": "pebble",
  "version": "0.1.0",
  "private": true,
  "description": "iMessage-to-Obsidian AI Vault Aggregator (MVP)",
  "type": "module",
  "bin": {
    "pebble": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "cli": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "@fastify/sensible": "^5.6.0",
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "fastify": "^4.28.1",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
